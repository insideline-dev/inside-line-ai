# ============================================
# REQUIRED — app will not start without these
# ============================================

# Cloud Postgres connection string
#   - In Docker (prod): set to your cloud Postgres URL (e.g. Neon connection string)
#   - In Docker (dev): set to the same, DEV_DATABASE_URL overrides it
DATABASE_URL=postgresql://user:password@host:5432/inside_line

# Override DB URL for local dev — useful to keep both prod/dev DBs separate.
# Only used when NODE_ENV=development.
# DEV_DATABASE_URL=postgresql://user:password@localhost:5432/inside_line_dev

# Optional DB pool tuning (safe defaults exist in code)
# DB_POOL_MAX=20
# DB_CONNECT_TIMEOUT_SECONDS=10
# DB_IDLE_TIMEOUT_SECONDS=30
# DB_MAX_LIFETIME_SECONDS=1800
# DB_DISABLE_PREPARE_FOR_POOLER=true

# Queue namespace. If two environments share Redis, they must use different prefixes.
# Local example: use a unique value per developer/branch.
QUEUE_PREFIX=inside-line-youssef-dev
# Production/staging examples: inside-line-prod / inside-line-staging

# Must be at least 32 characters
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Cloudflare R2 / S3 storage
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your-access-key
STORAGE_SECRET_ACCESS_KEY=your-secret-key
STORAGE_BUCKET=your-bucket

# ============================================
# DOCKER COMPOSE OVERRIDES (set automatically)
# Do NOT set these in .env — compose handles them
# ============================================
# NODE_ENV=production        (set by compose)
# PORT=8080                  (set by compose)
# REDIS_URL=redis://redis:6379  (set by compose)

# ============================================
# APP URLS
# For local Docker: defaults work (http://localhost)
# For production: set to your real domain
# ============================================
# APP_URL=https://yourdomain.com/api
# FRONTEND_URL=https://yourdomain.com
# Optional: override Chrome/Chromium executable for PDF rendering
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ============================================
# OPTIONAL — features work without these
# ============================================

# Storage CDN (if using custom domain for R2)
STORAGE_PROVIDER=r2
STORAGE_REGION=auto
STORAGE_PUBLIC_URL=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Inside Line <noreply@insideline.com>

# Feature flags
ENABLE_SWAGGER=false
LOG_TO_FILE=true
LOG_FILE_PATH=logs/backend.jsonl
LOG_CONTEXT_FILES_ENABLED=true
LOG_CONTEXT_FILES_DIR=logs/contexts
LOG_RUN_FILES_ENABLED=true
LOG_RUN_FILES_DIR=logs/runs
AI_AGENT_DEBUG_LOG_ENABLED=true
AI_AGENT_DEBUG_LOG_PATH=logs/ai-agent-debug.jsonl
AI_SCRAPING_DEBUG_LOG_ENABLED=true
AI_SCRAPING_DEBUG_LOG_PATH=logs/ai-scraping-debug.jsonl

# AI Providers (at least one needed for AI pipeline)
OPENAI_API_KEY=
MISTRAL_API_KEY=
# Only if you use Gemini models (see AI_MODEL_*): optional otherwise
# GOOGLE_AI_API_KEY=
# GOOGLE_API_KEY=

# AI Pipeline config
AI_PIPELINE_ENABLED=true
AI_ENRICHMENT_ENABLED=true
AI_MODEL_EXTRACTION=gpt-5.4-mini
AI_MODEL_RESEARCH=gpt-5.4-mini
AI_MODEL_EVALUATION=gpt-5.4-mini
AI_MODEL_SYNTHESIS=gpt-5.4
AI_MODEL_THESIS_ALIGNMENT=gpt-5.4-mini
AI_MODEL_LOCATION_NORMALIZATION=gpt-5.4-mini
AI_MODEL_OCR=mistral-ocr-latest

# AgentMail (Clara email assistant)
AGENTMAIL_API_KEY=
AGENTMAIL_WEBHOOK_SECRET=
CLARA_INBOX_ID=
CLARA_ADMIN_USER_ID=

# Twilio (WhatsApp notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Unipile (LinkedIn scraping)
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=
