# ============================================
# Docker Compose environment
# ============================================
# All backend env vars are loaded from backend/.env
# See backend/.env.example for the full list.
#
# These vars are used by docker-compose.yml directly:

# Port the frontend (nginx) listens on
PORT=80

# Production URLs (set to your real domain)
# These override the defaults in backend/.env
FRONTEND_URL=https://yourdomain.com
APP_URL=https://yourdomain.com/api
