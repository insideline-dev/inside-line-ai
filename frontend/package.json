{
  "name": "web",
  "private": true,
  "type": "module",
  "module": "src/main.tsx",
  "packageManager": "bun@1.3.1",
  "scripts": {
    "dev": "vite --port 3030 --host",
    "build": "bun run generate-routes && tsc -b && vite build",
    "preview": "vite preview",
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "generate:api": "openapi --input http://localhost:8080/reference --output ./src/lib/api-client --client fetch --exportModels false --postfixModels \"\" --exportSchemas false",
    "generate:api:full": "bun run generate:api && node scripts/fix-api-types.js"
  },
