# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend
FRONTEND_URL=http://localhost
VITE_API_URL=http://localhost:8080

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket

# Email (Resend)
RESEND_API_KEY=your-resend-api-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional
ENABLE_SWAGGER=false

# Redis
REDIS_URL=redis://localhost:6379

# AI Providers
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
# Optional backward-compatible alias
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# AI Pipeline
AI_PIPELINE_ENABLED=true
AI_PIPELINE_TTL_SECONDS=86400
AI_PIPELINE_TIMEOUT=600000
AI_MAX_RETRIES=3
AI_PIPELINE_MEMORY_MAX_ENTRIES=2000
AI_PIPELINE_REDIS_RECOVERY_INTERVAL_MS=30000
AI_MODEL_EXTRACTION=gemini-3.0-flash
AI_MODEL_RESEARCH=gemini-3.0-flash
AI_MODEL_EVALUATION=gemini-3.0-flash
AI_MODEL_SYNTHESIS=gpt-5.2
AI_MODEL_THESIS_ALIGNMENT=gemini-3.0-flash
AI_MODEL_LOCATION_NORMALIZATION=gemini-3.0-flash
AI_MODEL_OCR=mistral-ocr-latest
AI_RESEARCH_TEMPERATURE=0.2
AI_EVALUATION_TEMPERATURE=0.2
AI_EVALUATION_MAX_OUTPUT_TOKENS=4000
AI_SYNTHESIS_TEMPERATURE=0.2
AI_SYNTHESIS_MAX_OUTPUT_TOKENS=4000
AI_EXTRACTION_MAX_TEXT_CHARS=180000
AI_EXTRACTION_MAX_PDF_BYTES=104857600

# Phase 4: Web + LinkedIn Scraping
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=
WEBSITE_SCRAPE_TIMEOUT_MS=30000
LINKEDIN_BATCH_SIZE=10
SCRAPING_RATE_LIMIT_MS=1000
SCRAPING_MAX_SUBPAGES=20
SCRAPING_BATCH_SIZE=5
WEBSITE_CACHE_TTL_HOURS=24
LINKEDIN_CACHE_TTL_DAYS=7
SCRAPING_MAX_LINKS_PER_PAGE=100
SCRAPING_MAX_PATH_DEPTH=4
SCRAPING_MEMORY_CACHE_MAX_ENTRIES=5000
SCRAPING_CACHE_REDIS_RECOVERY_INTERVAL_MS=30000
