{
  "name": "web",
  "private": true,
  "type": "module",
  "module": "src/main.tsx",
  "packageManager": "bun@1.3.1",
  "scripts": {
    "dev": "vite --port 3030 --host",
    "build": "bun run generate-routes && tsc -b && vite build",
    "preview": "vite preview",
    "generate-routes": "tsr generate",
    "watch-routes": "tsr watch",
    "generate-api": "bun run scripts/generate-api.ts",
    "generate:api": "curl -s http://localhost:8080/docs-json > ./openapi.json && node fix-openapi.cjs && orval",
    "generate:api:watch": "orval --watch"
  },
