NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/boilerplate
# Redis Configuration (use REDIS_URL for simple setup)
REDIS_URL=redis://localhost:6379
# Or use individual vars (legacy, optional):
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_TLS=false

# Queue limits and concurrency
# Optional: isolate BullMQ keys per developer on shared Redis.
# Example: QUEUE_PREFIX=hassan-dev
# Remove/unset to revert to default BullMQ prefix behavior.
# QUEUE_PREFIX=
QUEUE_MAX_DEPTH_TASK=1000
QUEUE_MAX_PER_USER_TASK=20
QUEUE_MAX_DEPTH_AI_EXTRACTION=500
QUEUE_MAX_PER_USER_AI_EXTRACTION=5
QUEUE_MAX_DEPTH_AI_SCRAPING=500
QUEUE_MAX_PER_USER_AI_SCRAPING=5
QUEUE_MAX_DEPTH_AI_RESEARCH=500
QUEUE_MAX_PER_USER_AI_RESEARCH=5
QUEUE_MAX_DEPTH_AI_EVALUATION=500
QUEUE_MAX_PER_USER_AI_EVALUATION=5
QUEUE_MAX_DEPTH_AI_SYNTHESIS=500
QUEUE_MAX_PER_USER_AI_SYNTHESIS=5
AI_QUEUE_CONCURRENCY_EXTRACTION=4
AI_QUEUE_CONCURRENCY_SCRAPING=4
AI_QUEUE_CONCURRENCY_RESEARCH=6
AI_QUEUE_CONCURRENCY_EVALUATION=8
AI_QUEUE_CONCURRENCY_SYNTHESIS=2
# Optional legacy aliases used in docs:
# AI_EXTRACTION_CONCURRENCY=5
# AI_RESEARCH_CONCURRENCY=4
# AI_EVALUATION_CONCURRENCY=11
JWT_SECRET=your-super-secret-key-at-least-32-characters-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3030
ENABLE_SWAGGER=true
LOG_TO_FILE=true
LOG_FILE_PATH=logs/backend.jsonl
STORAGE_PROVIDER=r2
STORAGE_ENDPOINT=https://account.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=
STORAGE_PUBLIC_URL=
RESEND_API_KEY=
EMAIL_FROM=App <noreply@example.com>
AGENTMAIL_WEBHOOK_SECRET=
AGENTMAIL_API_KEY=
# Clara (AgentMail inbox routing + app actor identity)
# CLARA_INBOX_ID is the AgentMail inbox_id (not inbox email address)
CLARA_INBOX_ID=
# CLARA_ADMIN_USER_ID is the Inside Line admin user UUID (not an AgentMail value)
CLARA_ADMIN_USER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# Unipile (LinkedIn scraping)
UNIPILE_DSN=your-dsn.unipile.app
UNIPILE_API_KEY=your_api_key
UNIPILE_ACCOUNT_ID=your_account_id

# AI Pipeline
AI_PIPELINE_ENABLED=true
AI_PROMPT_RUNTIME_CONFIG_ENABLED=true
AI_PIPELINE_TTL_SECONDS=86400
AI_PIPELINE_TIMEOUT=600000
AI_MAX_RETRIES=3
AI_PIPELINE_MEMORY_MAX_ENTRIES=2000
AI_PIPELINE_REDIS_RECOVERY_INTERVAL_MS=30000
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
# Optional backward-compatible alias
GOOGLE_API_KEY=
MISTRAL_API_KEY=
AI_MODEL_EXTRACTION=gemini-3-flash-preview
AI_MODEL_RESEARCH=gemini-3-flash-preview
AI_MODEL_EVALUATION=gemini-3-flash-preview
AI_MODEL_SYNTHESIS=gemini-3-flash-preview
AI_MODEL_THESIS_ALIGNMENT=gemini-3-flash-preview
AI_MODEL_LOCATION_NORMALIZATION=gemini-3-flash-preview
AI_MODEL_OCR=mistral-ocr-latest
AI_RESEARCH_TEMPERATURE=0.2
AI_EVALUATION_TEMPERATURE=0.2
AI_EVALUATION_MAX_OUTPUT_TOKENS=4000
AI_SYNTHESIS_TEMPERATURE=0.2
AI_SYNTHESIS_MAX_OUTPUT_TOKENS=4000
AI_EXTRACTION_MAX_TEXT_CHARS=180000
AI_EXTRACTION_MAX_PDF_BYTES=104857600

# Scraping cache fallback tuning
SCRAPING_MEMORY_CACHE_MAX_ENTRIES=5000
SCRAPING_CACHE_REDIS_RECOVERY_INTERVAL_MS=30000
